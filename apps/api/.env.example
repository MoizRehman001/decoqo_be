NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://decoqo:decoqo_dev_pass@localhost:5432/decoqo_dev

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-256-bit-secret-minimum-32-chars
JWT_REFRESH_SECRET=change-me-refresh-256-bit-secret-min-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=decoqo-uploads
AWS_SES_FROM_EMAIL=noreply@decoqo.com

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx

# AI
REPLICATE_API_TOKEN=r8_xxx
OPENAI_API_KEY=sk-xxx

# KYC
SUREPASS_API_KEY=xxx

# SMS
MSG91_AUTH_KEY=xxx
MSG91_SENDER_ID=DECOQO
MSG91_OTP_TEMPLATE_ID=xxx

# Moderation Service
MODERATION_SERVICE_URL=http://localhost:8000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Sentry
SENTRY_DSN=

# App
APP_NAME=Decoqo
APP_URL=http://localhost:3000

# Admin Bootstrap — used ONCE to create the first SUPER_ADMIN account
# Must be at least 16 characters. Change this before deploying.
# After the first SUPER_ADMIN is created, this env var can be removed.
BOOTSTRAP_SECRET=change-me-bootstrap-secret-min-16-chars

# SMTP — Gmail (primary email transport for OTP)
# Use an App Password if 2FA is enabled on the Gmail account
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
