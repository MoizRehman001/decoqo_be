{
  "name": "@decoqo/api",
  "version": "1.0.0",
  "description": "Decoqo NestJS API — Trust Core MVP",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:local": "cross-env NODE_ENV=local nest start --watch",
    "start:dev": "cross-env NODE_ENV=development nest start --watch",
    "start:test": "cross-env NODE_ENV=test nest start --watch",
    "start:uat": "cross-env NODE_ENV=staging nest start",
    "start:prod": "cross-env NODE_ENV=production node dist/main",
    "start:debug": "cross-env NODE_ENV=local nest start --debug --watch",
    "db:migrate:local": "cross-env NODE_ENV=local dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:dev": "cross-env NODE_ENV=development dotenv -e .env.dev -- prisma migrate dev",
    "db:migrate:test": "cross-env NODE_ENV=test dotenv -e .env.test -- prisma migrate deploy",
    "db:migrate:uat": "cross-env NODE_ENV=staging dotenv -e .env.uat -- prisma migrate deploy",
    "db:migrate:prod": "cross-env NODE_ENV=production dotenv -e .env.prod -- prisma migrate deploy",
    "db:push:local": "dotenv -e .env.local -- prisma db push",
    "db:push:dev": "dotenv -e .env.dev -- prisma db push",
    "db:push:test": "dotenv -e .env.test -- prisma db push",
    "db:studio:local": "dotenv -e .env.local -- prisma studio",
    "db:studio:dev": "dotenv -e .env.dev -- prisma studio",
    "db:seed:local": "dotenv -e .env.local -- ts-node prisma/seed.ts",
    "db:seed:dev": "dotenv -e .env.dev -- ts-node prisma/seed.ts",
    "prisma:generate": "prisma generate",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:cov": "cross-env NODE_ENV=test jest --coverage",
    "test:unit": "cross-env NODE_ENV=test jest --testPathPattern=\\.spec\\.ts$",
    "test:integration": "cross-env NODE_ENV=test jest --testPathPattern=\\.integration\\.spec\\.ts$"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/client-ses": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0",
    "@nestjs/bullmq": "^10.1.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/event-emitter": "^2.0.4",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/schedule": "^4.0.1",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/throttler": "^5.1.2",
    "@nestjs/websockets": "^10.3.0",
    "@prisma/client": "^5.11.0",
    "@sentry/node": "^8.0.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/nodemailer": "^8.0.0",
    "axios": "^1.6.8",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.4.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "nest-winston": "^1.9.4",
    "nodemailer": "^8.0.6",
    "openai": "^4.29.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "razorpay": "^2.9.6",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.1",
    "replicate": "^0.29.4",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@nestjs/testing": "^10.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.30",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.3.1",
    "@typescript-eslint/parser": "^7.3.1",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.4",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.11.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2"
  }
}
